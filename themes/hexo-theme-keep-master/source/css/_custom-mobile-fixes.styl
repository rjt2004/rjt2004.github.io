@media (max-width: 900px) {
  .blog-container .blog-layout {
    display flex !important
    flex-direction column !important
  }

  .blog-container .blog-side {
    order -1 !important
    position static !important
    display flex !important
    flex-direction column !important
    width 100% !important
  }

  .record-wall-box .record-layout {
    display flex !important
    flex-direction column !important
  }

  .record-wall-box .record-timeline {
    order -1 !important
    position static !important
    width 100% !important
  }

  .record-wall-box .record-timeline-list {
    display flex !important
    flex-direction row !important
    flex-wrap wrap !important
  }

  .page-template-container .tools-nav-box {
    display flex !important
    flex-direction column !important
  }

  .page-template-container .tools-nav-box .tools-nav-list {
    position static !important
    display flex !important
    flex-wrap wrap !important
    gap 0.45rem !important
    width 100% !important
    max-width 100% !important
    max-height none !important
    margin-right 0 !important
    margin-bottom 1rem !important
  }

  .page-template-container .tools-nav-box .tools-nav-list .tool-nav-category {
    margin-bottom 0 !important
  }

  .header-weather-mobile .header-weather-panel {
    position fixed !important
    top 50vh !important
    left 50vw !important
    right auto !important
    bottom auto !important
    z-index 9999 !important
    width 20rem !important
    max-width 86vw !important
    transform translate(-50%, -50%) !important
  }

  .header-weather-mobile:hover .header-weather-panel,
  .header-weather-mobile:focus-within .header-weather-panel {
    transform translate(-50%, -50%) !important
  }
}

