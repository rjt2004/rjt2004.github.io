.first-screen-container {
  position relative
  width 100%
  height 100vh
  min-height 100vh
  overflow hidden
  background var(--background-color-1) url(hexo-config('first_screen.background_img')) center center / cover no-repeat

  .dark-mode & {
    background var(--background-color-1) url(hexo-config('first_screen.background_img_dark')) center center / cover no-repeat
  }

  .first-screen-content {
    position relative
    z-index 1
    display flex
    flex-direction column
    align-items center
    justify-content center
    width 80%
    height 100%
    min-height 100vh
    padding-top 0

    +keep-mobile() {
      width 90%
    }

    .home-profile {
      display flex
      flex-direction column
      align-items center
      justify-content center
      transform translateY(-1vh)
    }

    .home-avatar {
      display block
      width 136px
      height 136px
      object-fit cover
      border-radius 50%

      +keep-tablet() {
        width 124px
        height 124px
      }

      +keep-mobile() {
        width 108px
        height 108px
      }
    }

    .home-weather-status {
      display inline-flex
      align-items center
      gap 0.55rem
      margin-top 1.05rem
      color var(--first-screen-font-color-light)
      font-size 0.95rem
      line-height 1
      opacity 0.86

      img {
        display block
        width 2.15rem
        height 2.15rem
      }

    }

    .sc-icon-list {
      display flex
      justify-content center
      align-items center
      flex-wrap wrap
      gap 2.1rem
      margin-top 1.35rem

      .sc-icon-item {
        display flex
        align-items center
        justify-content center
        cursor pointer
        transition transform 0.18s ease

        &:hover {
          transform translateY(-2px)
        }

        i {
          color var(--first-screen-icon-color-light)
          font-size calc(var(--first-screen-icon-size) * 0.9)
        }

        svg {
          width calc(var(--first-screen-icon-size) * 0.9)
          height calc(var(--first-screen-icon-size) * 0.9)

          path {
            fill var(--first-screen-icon-color-light)
          }
        }

        +keep-mobile() {
          i {
            font-size calc(var(--first-screen-icon-size) * 0.78)
          }

          svg {
            width calc(var(--first-screen-icon-size) * 0.78)
            height calc(var(--first-screen-icon-size) * 0.78)
          }
        }

        a {
          display flex !important
          align-items center !important
          justify-content center !important
        }
      }
    }
  }
}

