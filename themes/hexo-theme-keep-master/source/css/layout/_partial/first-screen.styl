.first-screen-container {
  position relative
  width 100%
  height 100vh
  min-height 100vh
  overflow hidden
  background var(--background-color-1) url(hexo-config('first_screen.background_img')) center center / cover no-repeat

  .dark-mode & {
    background var(--background-color-1) url(hexo-config('first_screen.background_img_dark')) center center / cover no-repeat
  }

  .first-screen-content {
    position relative
    z-index 1
    display flex
    flex-direction column
    align-items center
    justify-content center
    width 80%
    height 100%
    min-height 100vh
    padding-top 0

    +keep-mobile() {
      width 90%
    }

    .home-profile {
      display flex
      flex-direction column
      align-items center
      justify-content center
      transform translateY(-1vh)
    }

    .home-profile-main {
      display flex
      align-items center
      justify-content center
      gap 2.4rem

      +keep-mobile() {
        flex-direction column
        gap 1.2rem
      }
    }

    .home-avatar {
      display block
      flex 0 0 auto
      width 136px
      height 136px
      object-fit cover
      border-radius 50%

      +keep-tablet() {
        width 124px
        height 124px
      }

      +keep-mobile() {
        width 108px
        height 108px
      }
    }

    .home-weather-card {
      display flex
      align-items center
      min-width 18rem
      max-width 22rem
      min-height 7.2rem
      padding 1rem 1.15rem
      color var(--first-screen-font-color-light)
      border 1px solid rgba(255, 255, 255, 0.34)
      border-radius 16px
      background rgba(255, 255, 255, 0.16)
      box-shadow 0 14px 40px rgba(0, 0, 0, 0.14)
      backdrop-filter blur(14px)
      -webkit-backdrop-filter blur(14px)

      .dark-mode & {
        border-color rgba(255, 255, 255, 0.16)
        background rgba(22, 24, 28, 0.34)
        box-shadow 0 16px 44px rgba(0, 0, 0, 0.24)
      }

      +keep-mobile() {
        width min(88vw, 21rem)
        min-width 0
        min-height 6.6rem
        padding 0.9rem 1rem
      }

      &.is-message {
        justify-content center
        text-align center
      }

      &.is-message .home-weather-icon-wrap,
      &.is-message .home-weather-main,
      &.is-message .home-weather-meta,
      &.is-message .home-weather-detail {
        display none
      }

      &.is-error .home-weather-place {
        opacity 0.82
      }
    }

    .home-weather-icon-wrap {
      display flex
      align-items center
      justify-content center
      flex 0 0 4.2rem
      width 4.2rem
      height 4.2rem
      margin-right 0.85rem
      border-radius 50%
      background rgba(255, 255, 255, 0.26)

      .dark-mode & {
        background rgba(255, 255, 255, 0.10)
      }
    }

    .home-weather-icon {
      display block
      width 3.45rem
      height 3.45rem
    }

    .home-weather-body {
      min-width 0
      line-height 1.35
    }

    .home-weather-place {
      margin-bottom 0.18rem
      font-size 0.82rem
      opacity 0.78
    }

    .home-weather-main {
      font-size 1.48rem
      font-weight 700
      white-space nowrap
    }

    .home-weather-meta,
    .home-weather-detail {
      margin-top 0.22rem
      font-size 0.82rem
      opacity 0.82
      white-space nowrap
    }

    .sc-icon-list {
      display flex
      justify-content center
      align-items center
      flex-wrap wrap
      gap 2.1rem
      margin-top 1.65rem

      .sc-icon-item {
        display flex
        align-items center
        justify-content center
        cursor pointer
        transition transform 0.18s ease

        &:hover {
          transform translateY(-2px)
        }

        i {
          color var(--first-screen-icon-color-light)
          font-size calc(var(--first-screen-icon-size) * 0.9)
        }

        svg {
          width calc(var(--first-screen-icon-size) * 0.9)
          height calc(var(--first-screen-icon-size) * 0.9)

          path {
            fill var(--first-screen-icon-color-light)
          }
        }

        +keep-mobile() {
          i {
            font-size calc(var(--first-screen-icon-size) * 0.78)
          }

          svg {
            width calc(var(--first-screen-icon-size) * 0.78)
            height calc(var(--first-screen-icon-size) * 0.78)
          }
        }

        a {
          display flex !important
          align-items center !important
          justify-content center !important
        }
      }
    }
  }
}